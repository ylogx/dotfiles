# vim: set filetype=shell
# Shared aliases — sourced by bash, zsh, and fish (via bass)
# Shell-specific overrides (reload, suffix aliases) are in:
#   zsh: ~/.zsh/05-aliases.zsh
#   bash: these are the defaults
#
# Tool checks (hash/lookPath) are resolved at chezmoi apply time.
# Re-run `chezmoi apply` after installing new tools to pick up aliases.
# Aliases ordered by usage frequency (based on zsh_history analysis).

##########
### ls ###  (l: 73 hits, la: 5)
##########
{{ if lookPath "eza" -}}
alias l='eza -lsnew'
alias leza='d; eza -bghHlS -s modified --git'
{{ else -}}
alias l='d; ls -ltrFhH'
{{ end -}}
alias la='d; ls -lAtrFhH'
alias ll='ls -alF'
alias lla='ls -a'
alias lsd='ls -l | grep "^d"'
alias nf='ls | wc -l'

#################
### File View ###  (c: 24 hits)
#################
alias less='less -R'
alias catlatest='cat `ls -t|head -1`'
alias wcl='wc -l'
{{ if lookPath "bat" -}}
alias c='temp_c() {[[ -d "$1" ]] && ls -ltrFhH "$1" || bat "$1"}; temp_c'
alias bp='temp_c() {[[ -d "$1" ]] && ls -ltrFhH "$1" || bat -P "$1"}; temp_c'
{{ else if lookPath "pygmentize" -}}
alias c='temp_c() {[[ -d "$1" ]] && ls -ltrFhH "$1" || pygmentize -g "$1"}; temp_c'
{{ else -}}
alias c='temp_c() {[[ -d "$1" ]] && ls -ltrFhH "$1" || cat "$1"}; temp_c'
{{ end -}}
{{ if lookPath "highlight" -}}
alias cats='highlight -O ansi'
{{ end -}}

#################
### Searching ###  (rg: 10 hits)
#################
alias rg='rg --hidden'
alias grepi='grep -i'

###########
### Git ###  (gcsc: 38 hits)
###########
alias gcsc='auto_commit staged commit'

############
### Misc ###  (cm: 9, rm: 4, watch: 3)
############
alias cm='chezmoi'
alias rm='rm -v'
alias watch='watch --color'
alias cl='clear'
alias p='pwd'
alias d='date'
alias wget='wget -c'
alias sudoh='sudo -H'
alias df='df -h'
alias du='du -h -c'
alias serve='python3 -m http.server'
alias py='python3'

#################
### Core/Shell ##  (reloads: 2)
#################
alias reload='reset; source ~/.bashrc'
alias reloads='source ~/.bashrc &> /dev/null'
{{ if lookPath "tree" -}}
alias t='tree -Csh'
alias t2='tree -Csh -L 2'
alias t3='tree -Csh -L 3'
alias t4='tree -Csh -L 4'
alias t5='tree -Csh -L 5'
{{ end -}}
{{ if lookPath "tmux" -}}
alias ta='tmux attach'
{{ end -}}
{{ if lookPath "ncdu" -}}
alias ncdu='ncdu --color dark -rr -x --exclude .git --exclude node_modules'
{{ end -}}
{{ if lookPath "docker" -}}
alias ctop='sudo docker run --rm -it --name=ctop -v /var/run/docker.sock:/var/run/docker.sock quay.io/vektorlab/ctop:latest'
{{ end -}}
{{ if lookPath "aria2c" -}}
alias a='aria2c -c -x 16'
{{ end -}}

#####################
### File/Dir Mgmt ###
#####################
alias cd..='cd ..'
alias cdw='cd ./`ls -td * | head -1`'
alias mkdirs='temp_c() {mkdir $1; cd $1}; temp_c'

# cd shortcuts — resolved at chezmoi apply time (only dirs that exist get aliases)
