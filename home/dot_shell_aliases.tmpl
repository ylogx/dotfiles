{{ if stat (joinPath .chezmoi.homeDir "code/work") -}}
alias cdz='cd ~/code/work'
{{ end -}}
{{ if stat (joinPath .chezmoi.homeDir "code/python") -}}
alias cdpy='cd ~/code/python'
{{ end -}}
{{ if stat (joinPath .chezmoi.homeDir "code/go") -}}
alias cdgo='cd ~/code/go'
{{ end -}}
{{ if stat (joinPath .chezmoi.homeDir "code/rust") -}}
alias cdru='cd ~/code/rust'
{{ end -}}
{{ if stat (joinPath .chezmoi.homeDir "code/ai") -}}
alias cdai='cd ~/code/ai'
{{ end -}}
{{ if stat (joinPath .chezmoi.homeDir "code/ai/ml") -}}
alias cdml='cd ~/code/ai/ml'
{{ end -}}
{{ if stat (joinPath .chezmoi.homeDir "code/me") -}}
