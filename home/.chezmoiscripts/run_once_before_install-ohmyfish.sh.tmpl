#!/bin/bash
{{ if ne .chezmoi.os "darwin" -}}
# Fish config is macOS-only in this setup
exit 0
{{ end -}}
set -eu

if command -v fish &>/dev/null && [ ! -d "$HOME/.local/share/omf" ]; then
    echo "Installing Oh My Fish..."
    curl -L https://get.oh-my.fish > /tmp/install-omf.fish
    fish /tmp/install-omf.fish --noninteractive || true
    rm -f /tmp/install-omf.fish
fi
