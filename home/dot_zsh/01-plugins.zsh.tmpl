# Static plugin loading via antidote (replaces antigen)
# Plugin list: ~/.zsh_plugins.txt
# To update plugins: antidote update
{{- if eq .chezmoi.os "darwin" }}
if [ -f "/opt/homebrew/share/antidote/antidote.zsh" ]; then
    source /opt/homebrew/share/antidote/antidote.zsh
elif [ -f "/usr/local/share/antidote/antidote.zsh" ]; then
    source /usr/local/share/antidote/antidote.zsh
else
    echo "Antidote not found. Install via: brew install antidote"
fi
{{- else }}
if [ -d "${ZDOTDIR:-~}/.antidote" ]; then
    source ${ZDOTDIR:-~}/.antidote/antidote.zsh
else
    echo "Antidote not found. Install via: git clone https://github.com/mattmc3/antidote ~/.antidote"
fi
{{- end }}

ZSH_HIGHLIGHT_HIGHLIGHTERS=(main brackets pattern cursor)
DISABLE_AUTO_UPDATE=true  # Skip oh-my-zsh upgrade check on every shell start

# Generate static plugin file when the plugin list changes, or when the
# antidote clone cache ($ANTIDOTE_HOME) is missing/empty. The mtime check
# alone isn't enough: Migration Assistant carries ~/.zsh_plugins.zsh over
# (it's a plain file in $HOME) but not ~/Library/Caches/antidote, so a
# stale-looking-fresh bundle can point at clones that no longer exist.
zsh_plugins=${ZDOTDIR:-$HOME}/.zsh_plugins
if [[ ! ${zsh_plugins}.zsh -nt ${zsh_plugins}.txt ]] || [[ -z "$(command ls -A "$ANTIDOTE_HOME" 2>/dev/null)" ]]; then
    antidote bundle <${zsh_plugins}.txt >${zsh_plugins}.zsh
fi
source ${zsh_plugins}.zsh

# Starship prompt (loaded directly, not through plugin manager)
eval "$(starship init zsh)"
