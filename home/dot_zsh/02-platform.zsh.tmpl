{{ if eq .chezmoi.os "linux" -}}
[ -d $JAVA_HOME/bin ] && export PATH=$JAVA_HOME/bin:$PATH
(( $+commands[xdg-open] )) && alias open='xdg-open'
{{ else if eq .chezmoi.os "darwin" -}}
if [ "$TERM" != "dumb" ]; then
    export LS_OPTIONS='--color=auto'
fi
alias ls="ls $LS_OPTIONS"
# GNU coreutils/sed (Homebrew)
[ -d /usr/local/opt/coreutils/libexec/gnubin ] && export PATH=/usr/local/opt/coreutils/libexec/gnubin:$PATH
[ -d /opt/homebrew/opt/coreutils/libexec/gnubin ] && export PATH=/opt/homebrew/opt/coreutils/libexec/gnubin:$PATH
[ -d /usr/local/opt/gnu-sed/libexec/gnubin ] && export PATH="/usr/local/opt/gnu-sed/libexec/gnubin:$PATH"
[ -d /opt/homebrew/opt/gnu-sed/libexec/gnubin ] && export PATH="/opt/homebrew/opt/gnu-sed/libexec/gnubin:$PATH"
[ -d /usr/local/share/npm/bin ] && export PATH="/usr/local/share/npm/bin:$PATH"
[ -d /usr/local/opt/coreutils/libexec/gnuman ] && export MANPATH="/usr/local/opt/coreutils/libexec/gnuman:$MANPATH"
[ -d /opt/homebrew/opt/coreutils/libexec/gnuman ] && export MANPATH="/opt/homebrew/opt/coreutils/libexec/gnuman:$MANPATH"
{{ end -}}

# SSH agent: only add keys if agent is already running (macOS Keychain or gpg-agent)
if [ -S "$SSH_AUTH_SOCK" ]; then
  ssh-add -l > /dev/null 2>&1 || ssh-add 2>/dev/null
fi
