{{ if eq .chezmoi.os "linux" -}}
[ -d $JAVA_HOME/bin ] && export PATH=$JAVA_HOME/bin:$PATH
(( $+commands[xdg-open] )) && alias open='xdg-open'
{{ else if eq .chezmoi.os "darwin" -}}
if [ "$TERM" != "dumb" ]; then
    export LS_OPTIONS='--color=auto'
fi
alias ls="ls $LS_OPTIONS"
# GNU coreutils/sed (Homebrew) — $HOMEBREW_PREFIX comes from `brew shellenv`
# in .zshenv, so this follows whichever prefix is active (/usr/local on
# Intel, /opt/homebrew on Apple Silicon) instead of hardcoding both.
[ -n "$HOMEBREW_PREFIX" ] && [ -d "$HOMEBREW_PREFIX/opt/coreutils/libexec/gnubin" ] && export PATH="$HOMEBREW_PREFIX/opt/coreutils/libexec/gnubin:$PATH"
[ -n "$HOMEBREW_PREFIX" ] && [ -d "$HOMEBREW_PREFIX/opt/gnu-sed/libexec/gnubin" ] && export PATH="$HOMEBREW_PREFIX/opt/gnu-sed/libexec/gnubin:$PATH"
[ -n "$HOMEBREW_PREFIX" ] && [ -d "$HOMEBREW_PREFIX/share/npm/bin" ] && export PATH="$HOMEBREW_PREFIX/share/npm/bin:$PATH"
[ -n "$HOMEBREW_PREFIX" ] && [ -d "$HOMEBREW_PREFIX/opt/coreutils/libexec/gnuman" ] && export MANPATH="$HOMEBREW_PREFIX/opt/coreutils/libexec/gnuman:$MANPATH"
{{ end -}}

# History (explicit — must be set after /etc/zshrc, which on macOS sets its
# own HISTSIZE=2000/SAVEHIST=1000 and would otherwise win; Linux has no
# equivalent /etc/zshrc default so this also gives us cross-platform parity)
HISTFILE="$HOME/.zsh_history"
HISTSIZE=100000
SAVEHIST=100000

# SSH agent: only add keys if agent is already running (macOS Keychain or gpg-agent)
if [ -S "$SSH_AUTH_SOCK" ]; then
  ssh-add -l > /dev/null 2>&1 || ssh-add 2>/dev/null
fi
