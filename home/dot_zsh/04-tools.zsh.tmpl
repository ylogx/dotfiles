# Tool inits — deferred where possible to avoid blocking shell startup
if (( $+commands[pyenv] )); then zsh-defer eval "$(pyenv init -)"; fi

(( $+commands[thefuck] )) && zsh-defer eval "$(thefuck --alias)"

# Google Cloud SDK
if [ -f "$HOME/sdk/google-cloud-sdk/path.zsh.inc" ]; then . "$HOME/sdk/google-cloud-sdk/path.zsh.inc"; fi
if [ -f "$HOME/sdk/google-cloud-sdk/completion.zsh.inc" ]; then . "$HOME/sdk/google-cloud-sdk/completion.zsh.inc"; fi

# FZF
# Prefer sourcing straight from the Homebrew keg — portable across Intel/Apple
# Silicon and avoids depending on ~/.fzf.zsh, which bakes in an absolute path
# from whichever machine last ran fzf's install script (doesn't survive
# migrating to a Mac with a different Homebrew prefix).
if [ -n "$HOMEBREW_PREFIX" ] && [ -f "$HOMEBREW_PREFIX/opt/fzf/shell/completion.zsh" ]; then
    source "$HOMEBREW_PREFIX/opt/fzf/shell/completion.zsh"
    source "$HOMEBREW_PREFIX/opt/fzf/shell/key-bindings.zsh"
elif [ -f ~/.fzf.zsh ]; then
    source ~/.fzf.zsh
fi
{{ if eq .chezmoi.os "linux" -}}
[ -f /usr/share/doc/fzf/examples/key-bindings.zsh ] && source /usr/share/doc/fzf/examples/key-bindings.zsh
{{ end -}}
# FZF_DEFAULT_COMMAND is set in ~/.config/shell/env.sh
# Up arrow: fzf history search, lands in buffer for editing.
# Ctrl-R: fzf history search, auto-executes the selection.
if (( $+functions[fzf-history-widget] )); then
    fzf-history-run-widget() {
        local prev_buffer="$BUFFER"
        fzf-history-widget
        [[ "$BUFFER" != "$prev_buffer" && -n "$BUFFER" ]] && zle accept-line
    }
    zle -N fzf-history-run-widget
    bindkey '^[[A' fzf-history-widget
    bindkey '^[OA' fzf-history-widget
    bindkey '^R' fzf-history-run-widget
fi
